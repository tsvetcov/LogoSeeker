      "targets": [{ "expr": "container_gpu_memory_total{container_label_com_docker_compose_service=\"logo_service\"} - container_gpu_memory_free{container_label_com_docker_compose_service=\"logo_service\"} or vector(0)", "legendFormat": "Занято видеопамяти (VRAM)", "refId": "A" }],
