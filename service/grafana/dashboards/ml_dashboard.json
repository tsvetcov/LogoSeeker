    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 6, "title": "🖥️ СИСТЕМНЫЕ РЕСУРСЫ КОНТЕЙНЕРОВ (CPU & RAM)", "type": "row" },
